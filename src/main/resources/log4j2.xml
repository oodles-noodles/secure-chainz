<?xml version="1.0" encoding="UTF-8"?>
<!-- Log4j2 configuration for the chainz-logger module -->
<Configuration status="WARN" name="ChainzLoggerConfig">
    <Appenders>
        <Console name="stdout" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} — %msg%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <Root level="info">
            <AppenderRef ref="stdout"/>
        </Root>
    </Loggers>
</Configuration>
